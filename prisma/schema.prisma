generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Submission {
  id        Int      @id @default(autoincrement())
  problemId String
  code      String
  language  String
  status    String
  output    String?
  runtime   Int?
  error     String?
  createdAt DateTime @default(now())
}